# Meraki Engine — environment variables
# Copy to .env and fill in your values

# Gemini API key for vision operations
GEMINI_API_KEY=your_api_key_here

# Executor VPS connection
EXECUTOR_HOST=your.vps.ip
EXECUTOR_SSH_KEY=/path/to/ssh/key

# Remote paths on executor
SESSION_DIR=/root/chrome-profile/sessions
MERAKI_ROOT=/root/meraki-engine
PROFILES_ROOT=/root/chrome-profiles

# Proxy port
PROXY_PORT=16666
